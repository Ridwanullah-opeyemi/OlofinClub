# Avoid committing secret environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Avoid committing locally installed packages (includes nodemailer)
node_modules/
jspm_packages/

# Avoid committing log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Mac operating system files
.DS_Store